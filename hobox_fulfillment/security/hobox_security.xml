<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record model="res.groups.privilege" id="res_groups_privilege_hobox">
        <field name="name">HOBOX Fulfillment</field>
        <field name="category_id" ref="base.module_category_inventory"/>
        <field name="sequence">90</field>
    </record>

    <record id="group_hobox_warehouse" model="res.groups">
        <field name="name">Warehouse Staff</field>
        <field name="privilege_id" ref="res_groups_privilege_hobox"/>
    </record>

    <record id="group_hobox_operations" model="res.groups">
        <field name="name">Operations Manager</field>
        <field name="privilege_id" ref="res_groups_privilege_hobox"/>
        <field name="implied_ids" eval="[(4, ref('hobox_fulfillment.group_hobox_warehouse'))]"/>
    </record>

    <record id="group_hobox_admin" model="res.groups">
        <field name="name">Administrator</field>
        <field name="privilege_id" ref="res_groups_privilege_hobox"/>
        <field name="user_ids" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
        <field name="implied_ids" eval="[(4, ref('hobox_fulfillment.group_hobox_operations'))]"/>
    </record>

</odoo>