<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- INHERIT PRODUCT FORM -->
    <record id="hobox_sku_form_view" model="ir.ui.view">
        <field name="name">product.template.form.hobox</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//group[@name='group_general']" position="inside">
                <field name="is_hobox_sku"/>
                <field name="hobox_client_id" invisible="not is_hobox_sku"/>
                <field name="storage_type" invisible="not is_hobox_sku"/>
            </xpath>
        </field>
    </record>

    <!-- INHERIT PRODUCT LIST -->
    <record id="hobox_sku_list_view" model="ir.ui.view">
        <field name="name">product.template.list.hobox</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_tree_view"/>
        <field name="arch" type="xml">

            <field name="default_code" position="after">
                <field name="hobox_client_id" optional="show"/>
                <field name="storage_type" optional="show"/>
            </field>

        </field>
    </record>

    <!-- ACTION -->
    <record id="action_hobox_skus" model="ir.actions.act_window">
        <field name="name">Products / SKUs</field>
        <field name="res_model">product.template</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('is_hobox_sku', '=', True)]</field>
        <field name="context">{'default_is_hobox_sku': True}</field>
    </record>

</odoo>