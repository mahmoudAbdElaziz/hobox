<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- INHERIT SALE ORDER FORM -->
    <record id="hobox_order_form_view" model="ir.ui.view">
        <field name="name">sale.order.form.hobox</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">

            <!-- Add HOBOX fields after partner_id -->
            <field name="partner_id" position="after">
                <field name="hobox_client_id"/>
                <field name="source_platform_id"
                    domain="[('partner_id','=',hobox_client_id)]"/>
                <field name="source_order_ref"/>
                <field name="delivery_zone"/>
                <field name="is_cod"/>
            </field>

            <!-- Add fulfillment statusbar before existing header buttons -->
            <xpath expr="//header" position="inside">
                <field name="hobox_state" widget="statusbar"
                    statusbar_visible="received,processing,ready,shipped,completed"/>
            </xpath>

        </field>
    </record>

    <!-- INHERIT SALE ORDER LIST -->
    <record id="hobox_order_list_view" model="ir.ui.view">
        <field name="name">sale.order.list.hobox</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_tree"/>
        <field name="arch" type="xml">

            <field name="partner_id" position="after">
                <field name="hobox_client_id" optional="show"/>
                <field name="source_platform_id" optional="show"/>
                <field name="source_order_ref" optional="show"/>
                <field name="delivery_zone" optional="show"/>
                <field name="is_cod" optional="show"/>
                <field name="hobox_state" optional="show" widget="badge"
                    decoration-success="hobox_state == 'completed'"
                    decoration-info="hobox_state == 'shipped'"
                    decoration-warning="hobox_state == 'processing'"
                    decoration-danger="hobox_state == 'cancelled'"/>
            </field>

        </field>
    </record>

    <!-- INHERIT SALE ORDER SEARCH -->
    <record id="hobox_order_search_view" model="ir.ui.view">
        <field name="name">sale.order.search.hobox</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_sales_order_filter"/>
        <field name="arch" type="xml">

            <filter name="my_sale_orders_filter" position="after">
                <field name="hobox_client_id"/>
                <field name="source_order_ref"/>
                <field name="source_platform_id"/>
                <separator/>
                <filter name="hobox_cod"        string="COD"        domain="[('is_cod','=',True)]"/>
                <filter name="hobox_received"   string="Received"   domain="[('hobox_state','=','received')]"/>
                <filter name="hobox_processing" string="Processing" domain="[('hobox_state','=','processing')]"/>
                <filter name="hobox_shipped"    string="Shipped"    domain="[('hobox_state','=','shipped')]"/>
                <filter name="hobox_completed"  string="Completed"  domain="[('hobox_state','=','completed')]"/>
                <filter name="hobox_cancelled"  string="Cancelled"  domain="[('hobox_state','=','cancelled')]"/>
            </filter>

            <group position="inside">
                <filter name="group_hobox_client"   string="HOBOX Client" context="{'group_by': 'hobox_client_id'}"/>
                <filter name="group_hobox_platform" string="Platform"     context="{'group_by': 'source_platform_id'}"/>
                <filter name="group_hobox_zone"     string="Zone"         context="{'group_by': 'delivery_zone'}"/>
                <filter name="group_hobox_state"    string="Fulfillment"  context="{'group_by': 'hobox_state'}"/>
            </group>

        </field>
    </record>

    <!-- ACTION -->
    <record id="action_hobox_orders" model="ir.actions.act_window">
        <field name="name">Orders</field>
        <field name="res_model">sale.order</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('hobox_client_id', '!=', False)]</field>
    </record>

</odoo>